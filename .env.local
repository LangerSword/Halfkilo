# Primary LLM — Groq (100% free, no credit card)
# Sign up: https://console.groq.com → API Keys → Create Key
# Model used: llama-3.3-70b-versatile (6000 tokens/min free)
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# Fallback LLM — Google AI Studio (100% free, no credit card)
# Sign up: https://aistudio.google.com → Get API Key → Create API Key
# Model used: gemini-2.0-flash (15 req/min, 250 req/day free)
GOOGLE_AI_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
