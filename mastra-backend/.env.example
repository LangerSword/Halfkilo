# Google Gemini (free tier) — get key at https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=

# MongoDB (local Docker or Atlas M0 free tier)
MONGODB_URI=mongodb://localhost:27017

# Contract addresses (after deploying to Avalanche Fuji)
PET_NFT_CONTRACT=0x0000000000000000000000000000000000000000
BATTLE_ARENA_CONTRACT=0x0000000000000000000000000000000000000000

# Deployer wallet private key (Fuji testnet only — get free AVAX at https://faucet.avax.network)
DEPLOYER_PRIVATE_KEY=0x

# Server ports (defaults)
API_PORT=3002
