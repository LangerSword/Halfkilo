{
  "name": "halfkilo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "mastra-backend",
    "contracts"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:mastra": "npm run dev --workspace=mastra-backend",
    "dev:ws": "npm run dev:ws --workspace=frontend",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:mastra\" \"npm run dev:ws\"",
    "build": "npm run build --workspaces",
    "compile:contracts": "npm run compile --workspace=contracts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
